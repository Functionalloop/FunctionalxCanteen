{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    "menu": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "broadcasts": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "orders": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "menuTemplates": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "tokenCounter": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
